<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mozen Academy — обучение менеджеров</title>
  <style>
    :root {
      --bg: #070b14;
      --bg-soft: #0d1424;
      --panel: rgba(14, 21, 37, 0.72);
      --panel-strong: rgba(18, 26, 45, 0.92);
      --line: rgba(255,255,255,0.08);
      --line-strong: rgba(255,255,255,0.16);
      --text: #f5f7fb;
      --muted: #a8b3c9;
      --accent: #ff4d4f;
      --accent-2: #6ea8ff;
      --success: #57d39b;
      --warn: #ffd166;
      --shadow: 0 22px 70px rgba(0,0,0,0.35);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --max: 1420px;
      --sidebar: 260px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      background:
        radial-gradient(circle at 10% 10%, rgba(255,77,79,0.14), transparent 25%),
        radial-gradient(circle at 100% 0%, rgba(110,168,255,0.16), transparent 28%),
        linear-gradient(180deg, #08101c 0%, #060912 52%, #05070d 100%);
      color: var(--text);
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; }

    .progress-bar {
      position: fixed;
      top: 0;
      left: 0;
      height: 4px;
      width: 0;
      background: linear-gradient(90deg, var(--accent), #ff8a4d, var(--accent-2));
      z-index: 2000;
      box-shadow: 0 0 22px rgba(255,77,79,0.55);
    }

    .shell {
      max-width: calc(var(--max) + 48px);
      margin: 0 auto;
      padding: 28px 24px 120px;
      display: grid;
      grid-template-columns: var(--sidebar) minmax(0, 1fr);
      gap: 24px;
    }

    .glass {
      background: linear-gradient(180deg, rgba(17, 24, 39, 0.86), rgba(10, 15, 27, 0.82));
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .sidebar {
      position: sticky;
      top: 20px;
      height: fit-content;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .brand {
      padding: 16px 16px 18px;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
      border: 1px solid var(--line);
    }

    .brand small {
      display: block;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 11px;
      margin-bottom: 10px;
    }

    .brand strong {
      display: block;
      font-size: 22px;
      line-height: 1.1;
      margin-bottom: 10px;
    }

    .brand p {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.55;
    }

    .sidebar nav {
      display: grid;
      gap: 10px;
    }

    .sidebar nav a {
      padding: 12px 14px;
      border-radius: 14px;
      color: var(--muted);
      border: 1px solid transparent;
      background: rgba(255,255,255,0.02);
      transition: 180ms ease;
      font-size: 14px;
      line-height: 1.35;
    }

    .sidebar nav a:hover,
    .sidebar nav a.active {
      color: var(--text);
      border-color: rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.06);
      transform: translateX(2px);
    }

    .sidebar-stat {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .sidebar-stat div {
      padding: 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
    }

    .sidebar-stat strong {
      display: block;
      font-size: 22px;
      margin-bottom: 4px;
    }

    .sidebar-stat span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.35;
    }

    .main {
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    .hero {
      position: relative;
      overflow: hidden;
      padding: 34px;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: -120px auto auto -120px;
      width: 280px;
      height: 280px;
      background: radial-gradient(circle, rgba(255,77,79,0.26), transparent 70%);
      pointer-events: none;
    }

    .hero::after {
      content: "";
      position: absolute;
      right: -110px;
      bottom: -120px;
      width: 320px;
      height: 320px;
      background: radial-gradient(circle, rgba(110,168,255,0.2), transparent 70%);
      pointer-events: none;
    }

    .hero-top {
      position: relative;
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      z-index: 1;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--line);
      color: #dce4f7;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .hero h1 {
      font-size: clamp(34px, 5vw, 62px);
      line-height: 0.95;
      margin: 18px 0 16px;
      max-width: 900px;
      letter-spacing: -0.04em;
    }

    .hero p.lead {
      max-width: 880px;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.7;
      margin: 0 0 20px;
      position: relative;
      z-index: 1;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      position: relative;
      z-index: 1;
    }

    .btn, .ghost-btn {
      border: 0;
      cursor: pointer;
      font: inherit;
      transition: 180ms ease;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 14px 18px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent), #ff7a45);
      color: white;
      font-weight: 700;
      box-shadow: 0 14px 30px rgba(255,77,79,0.2);
    }

    .btn:hover { transform: translateY(-1px); }

    .ghost-btn {
      padding: 13px 16px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      color: var(--text);
      border: 1px solid var(--line);
    }

    .ghost-btn:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-1px);
    }

    .hero-grid {
      margin-top: 28px;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 18px;
      position: relative;
      z-index: 1;
    }

    .source-card, .control-card {
      padding: 20px 22px;
      border-radius: 22px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
    }

    .source-card h3, .control-card h3 {
      margin: 0 0 10px;
      font-size: 18px;
    }

    .source-card p, .control-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      font-size: 14px;
    }

    .source-copy {
      display: grid;
      gap: 10px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 18px;
    }

    .stat {
      padding: 18px;
      border-radius: 20px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
    }

    .stat strong {
      display: block;
      font-size: 30px;
      line-height: 1;
      margin-bottom: 8px;
    }

    .stat span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .search-wrap {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .search-box {
      flex: 1;
      min-width: 220px;
      position: relative;
    }

    .search-box input {
      width: 100%;
      padding: 16px 18px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--text);
      outline: none;
      font: inherit;
    }

    .switches {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      color: var(--muted);
      cursor: pointer;
      user-select: none;
      font-size: 13px;
    }

    .pill input { accent-color: var(--accent); }

    .navigator {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 14px;
    }

    .nav-card {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 152px;
      transition: 180ms ease;
    }

    .nav-card:hover {
      transform: translateY(-3px);
      border-color: var(--line-strong);
    }

    .nav-card span {
      color: #d6def2;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .nav-card strong {
      font-size: 20px;
      line-height: 1.05;
    }

    .nav-card small {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .module {
      display: flex;
      flex-direction: column;
      gap: 18px;
      scroll-margin-top: 16px;
    }

    .module-head {
      padding: 28px;
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
    }

    .module-head h2 {
      margin: 14px 0 10px;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .module-subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 16px;
      line-height: 1.65;
      max-width: 780px;
    }

    .module-mark {
      min-width: 170px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: flex-end;
    }

    .module-index {
      font-size: 64px;
      line-height: 0.9;
      letter-spacing: -0.08em;
      color: rgba(255,255,255,0.16);
      font-weight: 800;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .chip {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.09);
      font-size: 12px;
      color: #d6def2;
    }

    .module-grid, .training-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .info-card, .train-card, .notes-card, .transcript, .quiz-card {
      padding: 24px;
    }

    .info-card h3, .train-card h3, .notes-card h3, .transcript h3, .quiz-card h3 {
      margin: 0 0 10px;
      font-size: 22px;
      line-height: 1.15;
    }

    .card-kicker {
      color: #d8e2ff;
      opacity: 0.9;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 11px;
      margin-bottom: 10px;
    }

    .info-card p, .train-card p, .notes-card p, .transcript p, .quiz-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
      font-size: 15px;
    }

    .bullet-list, .ordered-list {
      margin: 0;
      padding-left: 20px;
      color: var(--text);
      line-height: 1.7;
    }

    .bullet-list li, .ordered-list li {
      margin-bottom: 10px;
      color: #edf2ff;
    }

    .notes-head, .transcript-head, .quiz-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      margin-bottom: 16px;
    }

    .save-pill {
      font-size: 12px;
      color: var(--muted);
      padding: 8px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      white-space: nowrap;
    }

    textarea.module-notes {
      width: 100%;
      min-height: 170px;
      resize: vertical;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      padding: 18px;
      color: var(--text);
      font: inherit;
      line-height: 1.65;
      outline: none;
    }

    .transcript .lead-copy {
      margin-bottom: 18px;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
    }

    .details-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .detail-card {
      border-radius: 20px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      overflow: hidden;
    }

    .detail-card summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 20px;
      font-weight: 700;
      font-size: 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .detail-card summary::-webkit-details-marker { display: none; }

    .detail-card summary::after {
      content: "+";
      font-size: 22px;
      color: var(--muted);
      transition: 180ms ease;
    }

    .detail-card[open] summary::after {
      transform: rotate(45deg);
      color: var(--text);
    }

    .detail-body {
      padding: 0 20px 20px;
      color: var(--muted);
      border-top: 1px solid var(--line);
    }

    .topic-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-top: 14px;
    }

    .topic-card {
      padding: 18px;
      border-radius: 18px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
    }

    .topic-card h4 {
      margin: 0 0 10px;
      font-size: 17px;
      line-height: 1.35;
      color: var(--text);
    }

    .mini-title {
      margin: 18px 0 10px;
      font-size: 14px;
      line-height: 1.4;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #d8e2ff;
    }

    .label {
      color: #eef2ff;
      font-weight: 700;
    }

    .table-wrap {
      overflow-x: auto;
      margin-top: 16px;
      border-radius: 16px;
      border: 1px solid var(--line);
    }

    table.academy-table {
      width: 100%;
      border-collapse: collapse;
      min-width: 680px;
      background: rgba(255,255,255,0.02);
    }

    .academy-table th,
    .academy-table td {
      padding: 14px 16px;
      text-align: left;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      line-height: 1.55;
      font-size: 14px;
    }

    .academy-table th {
      background: rgba(255,255,255,0.05);
      color: var(--text);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    mark {
      background: rgba(255, 209, 102, 0.18);
      color: #fff7d6;
      padding: 0 4px;
      border-radius: 4px;
    }

    .quiz-questions {
      display: grid;
      gap: 16px;
    }

    .quiz-item {
      padding: 18px;
      border-radius: 18px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--line);
    }

    .quiz-item h4 {
      margin: 0 0 12px;
      font-size: 16px;
      line-height: 1.45;
    }

    .quiz-options {
      display: grid;
      gap: 10px;
    }

    .quiz-option {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(255,255,255,0.03);
      border: 1px solid transparent;
      cursor: pointer;
      transition: 150ms ease;
      color: #eef2ff;
      line-height: 1.5;
    }

    .quiz-option:hover {
      border-color: var(--line-strong);
      background: rgba(255,255,255,0.05);
    }

    .quiz-option.correct {
      border-color: rgba(87,211,155,0.45);
      background: rgba(87,211,155,0.12);
    }

    .quiz-option.wrong {
      border-color: rgba(255,77,79,0.45);
      background: rgba(255,77,79,0.12);
    }

    .quiz-option input {
      margin-top: 3px;
      accent-color: var(--accent);
    }

    .quiz-result {
      margin-top: 16px;
      padding: 16px 18px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line);
      color: var(--text);
      display: none;
    }

    .quiz-result.visible { display: block; }

    .hidden-by-search { display: none !important; }
    .full-only.compact-hidden { display: none !important; }

    .completed .module-head {
      border-color: rgba(87,211,155,0.32);
      box-shadow: 0 22px 70px rgba(0,0,0,0.35), 0 0 0 1px rgba(87,211,155,0.18) inset;
    }

    .scroll-top {
      position: fixed;
      right: 22px;
      bottom: 22px;
      width: 52px;
      height: 52px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      border: 1px solid var(--line);
      background: rgba(10,15,27,0.84);
      color: var(--text);
      cursor: pointer;
      box-shadow: var(--shadow);
      opacity: 0;
      pointer-events: none;
      transition: 180ms ease;
      z-index: 1000;
    }

    .scroll-top.visible {
      opacity: 1;
      pointer-events: auto;
    }

    @media (max-width: 1180px) {
      .shell {
        grid-template-columns: 1fr;
      }
      .sidebar {
        position: relative;
        top: 0;
      }
      .navigator {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .hero-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 820px) {
      .shell {
        padding: 16px 14px 100px;
      }
      .hero, .module-head, .info-card, .train-card, .notes-card, .transcript, .quiz-card {
        padding: 20px;
      }
      .module-grid, .training-grid, .topic-grid, .stats-grid {
        grid-template-columns: 1fr;
      }
      .module-head {
        flex-direction: column;
      }
      .module-mark {
        align-items: flex-start;
        min-width: 0;
      }
      .module-index {
        font-size: 48px;
      }
      .navigator {
        grid-template-columns: 1fr;
      }
      .hero h1 {
        font-size: 34px;
        line-height: 1.02;
      }
    }
  </style>
  <style>
    :root {
      --bg: #f8fafc;
      --bg-soft: #eef2f7;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --panel-strong: #0f172a;
      --line: #e2e8f0;
      --line-strong: #cbd5e1;
      --text: #0f172a;
      --muted: #64748b;
      --muted-strong: #475569;
      --accent: #10b981;
      --accent-2: #3b82f6;
      --accent-soft: #ecfdf5;
      --success: #22c55e;
      --warn: #f59e0b;
      --danger: #ef4444;
      --shadow: 0 1px 3px rgba(15,23,42,0.06), 0 18px 42px rgba(15,23,42,0.08);
      --shadow-soft: 0 1px 2px rgba(15,23,42,0.04), 0 10px 28px rgba(15,23,42,0.06);
      --max: 1440px;
      --sidebar: 284px;
    }

    :focus-visible {
      outline: 3px solid rgba(59,130,246,0.18);
      outline-offset: 2px;
    }

    body {
      background:
        radial-gradient(circle at 0% 0%, rgba(16,185,129,0.08), transparent 26%),
        radial-gradient(circle at 100% 0%, rgba(59,130,246,0.09), transparent 32%),
        linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
      color: var(--text);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    ::selection { background: rgba(16,185,129,0.18); }

    .progress-bar {
      height: 3px;
      background: linear-gradient(90deg, #0f172a, #334155);
      box-shadow: 0 0 12px rgba(15,23,42,0.16);
    }

    .shell {
      max-width: calc(var(--max) + 40px);
      padding: 20px 20px 96px;
      align-items: start;
    }

    .glass {
      background: var(--panel);
      border-color: var(--line);
      box-shadow: var(--shadow-soft);
      backdrop-filter: none;
    }

    .sidebar {
      min-height: calc(100vh - 40px);
      padding: 0;
      gap: 0;
      overflow: auto;
    }

    .brand {
      padding: 22px 20px 20px;
      border-radius: 0;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      border: 0;
      border-bottom: 1px solid var(--line);
    }

    .brand strong { color: var(--text); }
    .brand p { color: var(--muted); }

    .sidebar nav {
      gap: 6px;
      padding: 12px;
    }

    .sidebar nav a {
      color: var(--muted);
      background: transparent;
      font-weight: 500;
    }

    .sidebar nav a:hover {
      color: var(--text);
      border-color: var(--line);
      background: var(--panel-soft);
      transform: translateX(3px);
    }

    .sidebar nav a.active {
      color: #ffffff;
