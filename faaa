  <script>
    const modules = Array.from(document.querySelectorAll('.module'));
    const sideLinks = Array.from(document.querySelectorAll('#sideNav a'));
    const navLinks = Array.from(document.querySelectorAll('.nav-card'));
    const progressBar = document.getElementById('progressBar');
    const scrollTopBtn = document.getElementById('scrollTopBtn');
    const searchInput = document.getElementById('globalSearch');
    const compactMode = document.getElementById('compactMode');
    const hideCompleted = document.getElementById('hideCompleted');
    const expandAllBtn = document.getElementById('expandAllBtn');

    function updateProgress() {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const percent = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
      progressBar.style.width = percent + '%';
      scrollTopBtn.classList.toggle('visible', window.scrollY > 500);
    }

    function setActiveSection() {
      let currentId = modules[0]?.id;
      modules.forEach(section => {
        const rect = section.getBoundingClientRect();
        if (rect.top <= 160) currentId = section.id;
      });
      [...sideLinks, ...navLinks].forEach(link => {
        const href = (link.getAttribute('href') || '').replace('#', '');
        link.classList.toggle('active', href === currentId);
      });
    }

    function highlightText(element, query) {
      if (!element.dataset.rawHtml) element.dataset.rawHtml = element.innerHTML;
      if (!query) {
        element.innerHTML = element.dataset.rawHtml;
        return;
      }
      const safeQuery = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp('(' + safeQuery + ')', 'gi');
      element.innerHTML = element.dataset.rawHtml.replace(regex, '<mark>$1</mark>');
    }

    function performSearch() {
      const query = searchInput.value.trim().toLowerCase();
      modules.forEach(module => {
        const searchable = Array.from(module.querySelectorAll('.searchable'));
        let matched = !query;
        searchable.forEach(node => {
          highlightText(node, query);
          if (query && node.textContent.toLowerCase().includes(query)) matched = true;
        });
        module.classList.toggle('hidden-by-search', !matched);
      });
      navLinks.forEach(link => {
        const target = document.querySelector(link.getAttribute('href'));
        link.classList.toggle('hidden-by-search', target?.classList.contains('hidden-by-search'));
      });
      sideLinks.forEach(link => {
        const target = document.querySelector(link.getAttribute('href'));
        link.classList.toggle('hidden-by-search', target?.classList.contains('hidden-by-search'));
      });
    }

    function applyCompactMode() {
      document.querySelectorAll('.full-only').forEach(node => {
        node.classList.toggle('compact-hidden', compactMode.checked);
      });
      localStorage.setItem('mozen_compact_mode', compactMode.checked ? '1' : '0');
    }

    function applyCompletedFilter() {
      const completed = JSON.parse(localStorage.getItem('mozen_completed_modules') || '[]');
      modules.forEach(module => {
        const isCompleted = completed.includes(module.id);
        module.classList.toggle('completed', isCompleted);
        if (hideCompleted.checked && isCompleted) {
          module.classList.add('hidden-by-search');
        } else if (!searchInput.value.trim()) {
          module.classList.remove('hidden-by-search');
        }
      });
      navLinks.forEach(link => {
        const target = document.querySelector(link.getAttribute('href'));
        link.classList.toggle('hidden-by-search', target?.classList.contains('hidden-by-search'));
      });
      sideLinks.forEach(link => {
        const target = document.querySelector(link.getAttribute('href'));
        link.classList.toggle('hidden-by-search', target?.classList.contains('hidden-by-search'));
      });
      localStorage.setItem('mozen_hide_completed', hideCompleted.checked ? '1' : '0');
    }

    function toggleComplete(moduleId) {
      const current = JSON.parse(localStorage.getItem('mozen_completed_modules') || '[]');
      const next = current.includes(moduleId)
        ? current.filter(id => id !== moduleId)
        : [...current, moduleId];
      localStorage.setItem('mozen_completed_modules', JSON.stringify(next));
      applyCompletedFilter();
    }

    document.querySelectorAll('.mark-complete').forEach(btn => {
      btn.addEventListener('click', () => toggleComplete(btn.dataset.target));
    });

    document.querySelectorAll('.module-notes').forEach(area => {
      const key = 'mozen_note_' + area.dataset.notes;
      area.value = localStorage.getItem(key) || '';
      area.addEventListener('input', () => localStorage.setItem(key, area.value));
    });

    document.querySelectorAll('.section-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const container = btn.closest('.transcript');
        const details = Array.from(container.querySelectorAll('details'));
        const shouldOpen = btn.dataset.mode !== 'collapse';
        details.forEach(d => d.open = shouldOpen);
        btn.dataset.mode = shouldOpen ? 'collapse' : 'expand';
        btn.textContent = shouldOpen ? 'Свернуть все' : 'Раскрыть все';
      });
    });

    expandAllBtn.addEventListener('click', () => {
      document.querySelectorAll('.details-stack details').forEach(d => d.open = true);
      document.querySelectorAll('.section-toggle').forEach(btn => {
        btn.dataset.mode = 'collapse';
        btn.textContent = 'Свернуть все';
      });
      compactMode.checked = false;
      applyCompactMode();
      window.location.hash = '#modules';
    });

    scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    searchInput.addEventListener('input', () => {
      performSearch();
      if (hideCompleted.checked) applyCompletedFilter();
    });
    compactMode.addEventListener('change', applyCompactMode);
    hideCompleted.addEventListener('change', applyCompletedFilter);

    function renderQuiz(card) {
      const data = JSON.parse(card.dataset.quiz);
      const wrap = card.querySelector('.quiz-questions');
      wrap.innerHTML = data.map((item, index) => `
        <div class="quiz-item">
          <h4>${index + 1}. ${item.q}</h4>
          <div class="quiz-options">
            ${item.options.map((option, optionIndex) => `
              <label class="quiz-option">
                <input type="radio" name="quiz-${card.closest('.module').id}-${index}" value="${optionIndex}" />
                <span>${option}</span>
              </label>
            `).join('')}
          </div>
        </div>
      `).join('');
    }

    document.querySelectorAll('.quiz-card').forEach(card => {
      renderQuiz(card);
      const btn = card.querySelector('.run-quiz');
      const result = card.querySelector('.quiz-result');
      btn.addEventListener('click', () => {
        const data = JSON.parse(card.dataset.quiz);
        let correct = 0;
        const items = Array.from(card.querySelectorAll('.quiz-item'));
        items.forEach((item, qIndex) => {
          const selected = item.querySelector('input[type="radio"]:checked');
          const options = Array.from(item.querySelectorAll('.quiz-option'));
          options.forEach((opt, optIndex) => {
            opt.classList.remove('correct', 'wrong');
            if (optIndex === data[qIndex].answer) opt.classList.add('correct');
          });
          if (selected && Number(selected.value) === data[qIndex].answer) {
            correct += 1;
          } else if (selected) {
            selected.closest('.quiz-option')?.classList.add('wrong');
          }
        });
        const percent = Math.round((correct / data.length) * 100);
        let note = 'Неплохо, но лучше еще раз пройтись по алгоритму разговора и ключевым аргументам.';
        if (percent >= 90) note = 'Отличный результат. Этот блок можно считать хорошо усвоенным.';
        else if (percent >= 70) note = 'Хорошо. Осталось укрепить детали и формулировки.';
        result.classList.add('visible');
        result.innerHTML = `<strong>Результат: ${correct} / ${data.length} (${percent}%)</strong><br>${note}`;
      });
    });

    // restore settings
    compactMode.checked = localStorage.getItem('mozen_compact_mode') === '1';
    hideCompleted.checked = localStorage.getItem('mozen_hide_completed') === '1';
    applyCompactMode();
    applyCompletedFilter();

    window.addEventListener('scroll', () => {
      updateProgress();
      setActiveSection();
    });
    window.addEventListener('load', () => {
      updateProgress();
      setActiveSection();
      performSearch();
    });
  </script>
