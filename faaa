      <article class="quiz-card glass" data-quiz='[{&quot;q&quot;: &quot;Для кого лучше всего подходит универсальный кабинет?&quot;, &quot;options&quot;: [&quot;Только для крупнейших сетей&quot;, &quot;Для клиентов без сложной интеграции и с небольшим числом исполнителей&quot;, &quot;Только для бьюти&quot;, &quot;Только для авто&quot;], &quot;answer&quot;: 1}, {&quot;q&quot;: &quot;Что является одним из ключевых отличий вторсырья от лома в лекции?&quot;, &quot;options&quot;: [&quot;Во вторсырье всегда нужна офлайн-касса&quot;, &quot;Во вторсырье часто достаточно онлайн-кассы, а не офлайн-кассы как в ломе&quot;, &quot;Во вторсырье нет документов&quot;, &quot;Во вторсырье запрещены выплаты&quot;], &quot;answer&quot;: 1}, {&quot;q&quot;: &quot;Когда лучше всего продавать решение для дикоросов?&quot;, &quot;options&quot;: [&quot;После окончания сезона&quot;, &quot;Весной, до начала сезона&quot;, &quot;Только зимой&quot;, &quot;В любой момент без разницы&quot;], &quot;answer&quot;: 1}, {&quot;q&quot;: &quot;Какой формат запуска предлагается клиенту для снижения порога входа?&quot;, &quot;options&quot;: [&quot;Сразу сложная ERP-интеграция&quot;, &quot;Тест-драйв на универсальном кабинете&quot;, &quot;Только офлайн-касса&quot;, &quot;Переход на наличку&quot;], &quot;answer&quot;: 1}, {&quot;q&quot;: &quot;Во что может вырасти клиент после старта на Lite?&quot;, &quot;options&quot;: [&quot;Только в отказ от сервиса&quot;, &quot;В более сложные отраслевые решения Mozen&quot;, &quot;В маркетплейс&quot;, &quot;В страховую компанию&quot;], &quot;answer&quot;: 1}]'>
        <div class="quiz-head">
          <div>
            <div class="card-kicker">Проверка знаний</div>
            <h3>Мини-тест по блоку</h3>
          </div>
          <button class="ghost-btn run-quiz">Проверить ответы</button>
